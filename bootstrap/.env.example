# Copy this file to bootstrap/.env and edit paths for your machine.
# The setup script fails loud (won't produce a broken config) if any of
# these are missing from .env when the rendered config needs them.

# Where the MCP Hub V12 repository is cloned locally
# (https://github.com/0xC1pher/MCP-HUB-V11 — repo name is V11, content is V12).
MCP_HUB_V12_REPO_PATH=
# Where to create the MCP Hub V12 venv (any writable directory).
MCP_HUB_V12_VENV_PATH=
# Full path to the python.exe inside that venv.
MCP_HUB_V12_VENV_PYTHON=
# Path to requirements.txt inside the cloned repo (used by the venv pip install step).
MCP_HUB_V12_REQUIREMENTS=
