# Copy this file to bootstrap/.env and edit paths for your machine.
# The setup script fails loud (won't produce a broken config) if any of
# these are missing from .env when the rendered config needs them.

# Where to create the yari-mcp-v8 venv (any writable directory).
MCP_HUB_V8_VENV_PATH=
# Full path to the python.exe inside that venv.
MCP_HUB_V8_VENV_PYTHON=
# Path to the yari-mcp-v8 server.py you actually want to run.
MCP_HUB_V8_SERVER_PY=
# Path to its requirements.txt (used by the venv pip install step).
MCP_HUB_V8_REQUIREMENTS=
